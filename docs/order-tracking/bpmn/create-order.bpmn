<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Def_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Luồng tạo đơn hàng" processRef="Process_create-order" />
  </bpmn:collaboration>
  <bpmn:process id="Process_create-order" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Sales" name="Maker (Sales)">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Action</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Edit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Input</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Submit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Fix</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="Hệ thống">
        <bpmn:flowNodeRef>GW_Validate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Invalid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Init</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_CheckState</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Update</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RejectEdit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_API</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_API</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_APISuccess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Success</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_APIFail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_APIFail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RejectEdit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Export</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Refund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admin" name="Checker (Admin)">
        <bpmn:flowNodeRef>Task_View</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Approve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Reject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Reject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Approve</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Bắt đầu tạo đơn">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_Validate" name="Dữ liệu hợp lệ &#38; đủ số lượng?">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
      <bpmn:outgoing>F7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Invalid" name="Trả về lỗi &#38; highlight trường sai">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Init" name="Khởi tạo đơn hàng (Chờ duyệt) &#38; Tạm giữ số lượng">
      <bpmn:incoming>F7</bpmn:incoming>
      <bpmn:outgoing>F8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Action" name="Hành động tiếp theo?">
      <bpmn:incoming>F8</bpmn:incoming>
      <bpmn:incoming>F12</bpmn:incoming>
      <bpmn:outgoing>F9</bpmn:outgoing>
      <bpmn:outgoing>F15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Edit" name="Sửa thông tin đơn &#38; Bấm Lưu chỉnh sửa">
      <bpmn:incoming>F9</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_CheckState" name="Đơn đã được duyệt/từ chối chưa?">
      <bpmn:incoming>F10</bpmn:incoming>
      <bpmn:outgoing>F11</bpmn:outgoing>
      <bpmn:outgoing>F13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Update" name="Lưu cập nhật, tăng Version, báo thành công">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:outgoing>F12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RejectEdit" name="Từ chối lưu &#38; báo lỗi">
      <bpmn:incoming>F13</bpmn:incoming>
      <bpmn:outgoing>F14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_View" name="Xem danh sách và chi tiết đơn chờ duyệt">
      <bpmn:incoming>F15</bpmn:incoming>
      <bpmn:outgoing>F16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Approve" name="Quyết định phê duyệt?">
      <bpmn:incoming>F16</bpmn:incoming>
      <bpmn:outgoing>F17</bpmn:outgoing>
      <bpmn:outgoing>F20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Reject" name="Nhập lý do &#38; Xác nhận từ chối">
      <bpmn:incoming>F17</bpmn:incoming>
      <bpmn:outgoing>F18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Reject" name="Đơn bị từ chối">
      <bpmn:incoming>F19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Approve" name="Bấm Phê duyệt">
      <bpmn:incoming>F20</bpmn:incoming>
      <bpmn:outgoing>F21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_API" name="Gọi API tạo vận đơn sang 247Express">
      <bpmn:incoming>F22</bpmn:incoming>
      <bpmn:outgoing>F23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_API" name="Kết nối API thành công?">
      <bpmn:incoming>F23</bpmn:incoming>
      <bpmn:outgoing>F24</bpmn:outgoing>
      <bpmn:outgoing>F26</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_APISuccess" name="Lưu Tracking ID &#38; Đổi sang Đã tiếp nhận">
      <bpmn:incoming>F24</bpmn:incoming>
      <bpmn:outgoing>F25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Success" name="Tạo đơn thành công">
      <bpmn:incoming>F25</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_APIFail" name="Đặt COURIER_Thất bại &#38; Cảnh báo gửi lại API">
      <bpmn:incoming>F26</bpmn:incoming>
      <bpmn:outgoing>F27</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_APIFail" name="Lỗi kết nối HVC">
      <bpmn:incoming>F27</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" name="" sourceRef="Start_1" targetRef="Task_Input" />
    <bpmn:sequenceFlow id="F2" name="" sourceRef="Task_Input" targetRef="Task_Submit" />
    <bpmn:sequenceFlow id="F3" name="" sourceRef="Task_Submit" targetRef="GW_Validate" />
    <bpmn:sequenceFlow id="F4" name="Thất bại" sourceRef="GW_Validate" targetRef="Task_Invalid" />
    <bpmn:sequenceFlow id="F5" name="" sourceRef="Task_Invalid" targetRef="Task_Fix" />
    <bpmn:sequenceFlow id="F6" name="" sourceRef="Task_Fix" targetRef="Task_Submit" />
    <bpmn:sequenceFlow id="F7" name="Thành công" sourceRef="GW_Validate" targetRef="Task_Init" />
    <bpmn:sequenceFlow id="F8" name="" sourceRef="Task_Init" targetRef="GW_Action" />
    <bpmn:sequenceFlow id="F9" name="Sales sửa đơn" sourceRef="GW_Action" targetRef="Task_Edit" />
    <bpmn:sequenceFlow id="F10" name="" sourceRef="Task_Edit" targetRef="GW_CheckState" />
    <bpmn:sequenceFlow id="F11" name="Chưa bị xử lý" sourceRef="GW_CheckState" targetRef="Task_Update" />
    <bpmn:sequenceFlow id="F12" name="" sourceRef="Task_Update" targetRef="GW_Action" />
    <bpmn:sequenceFlow id="F13" name="Đã bị xử lý" sourceRef="GW_CheckState" targetRef="Task_RejectEdit" />
    <bpmn:sequenceFlow id="F14" name="" sourceRef="Task_RejectEdit" targetRef="End_RejectEdit" />
    <bpmn:sequenceFlow id="F15" name="Admin duyệt đơn" sourceRef="GW_Action" targetRef="Task_View" />
    <bpmn:sequenceFlow id="F16" name="" sourceRef="Task_View" targetRef="GW_Approve" />
    <bpmn:sequenceFlow id="F17" name="Từ chối" sourceRef="GW_Approve" targetRef="Task_Reject" />
    <bpmn:sequenceFlow id="F18" name="" sourceRef="Task_Reject" targetRef="Task_Refund" />
    <bpmn:sequenceFlow id="F19" name="" sourceRef="Task_Refund" targetRef="End_Reject" />
    <bpmn:sequenceFlow id="F20" name="Phê duyệt" sourceRef="GW_Approve" targetRef="Task_Approve" />
    <bpmn:sequenceFlow id="F21" name="" sourceRef="Task_Approve" targetRef="Task_Export" />
    <bpmn:sequenceFlow id="F22" name="" sourceRef="Task_Export" targetRef="Task_API" />
    <bpmn:sequenceFlow id="F23" name="" sourceRef="Task_API" targetRef="GW_API" />
    <bpmn:sequenceFlow id="F24" name="Thành công" sourceRef="GW_API" targetRef="Task_APISuccess" />
    <bpmn:sequenceFlow id="F25" name="" sourceRef="Task_APISuccess" targetRef="End_Success" />
    <bpmn:sequenceFlow id="F26" name="Thất bại" sourceRef="GW_API" targetRef="Task_APIFail" />
    <bpmn:sequenceFlow id="F27" name="" sourceRef="Task_APIFail" targetRef="End_APIFail" />
    <bpmn:task id="Task_Input" name="Mở form, chọn Yêu cầu, nhập số lượng, đính kèm Hóa đơn">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Submit" name="Bấm Xác nhận tạo đơn">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:incoming>F6</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Fix" name="Sửa thông tin lỗi">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_RejectEdit" name="Không thể sửa">
      <bpmn:incoming>F14</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Export" name="Sinh Bản ghi Xuất kho (Chờ duyệt) &#38; Gửi SMS cho KH">
      <bpmn:incoming>F21</bpmn:incoming>
      <bpmn:outgoing>F22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Refund" name="Giải phóng số lượng tạm giữ, chuyển Từ Chối, Auto Refund">
      <bpmn:incoming>F18</bpmn:incoming>
      <bpmn:outgoing>F19</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
