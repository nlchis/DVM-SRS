<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Def_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Đặt &amp; giao đồ ăn — đầu cuối" processRef="Process_order_fulfillment"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_order_fulfillment" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_customer" name="Khách"><bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef><bpmn:flowNodeRef>End_payfail</bpmn:flowNodeRef><bpmn:flowNodeRef>End_cancel</bpmn:flowNodeRef><bpmn:flowNodeRef>End_failed</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_receive</bpmn:flowNodeRef><bpmn:flowNodeRef>End_done</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_system" name="Hệ thống"><bpmn:flowNodeRef>Task_total</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_online</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_pay</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_paid</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_send</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_refund</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_assign</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_shipper</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_fail</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_restaurant" name="Nhà hàng"><bpmn:flowNodeRef>GW_accept</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_prepare</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_shipper" name="Shipper"><bpmn:flowNodeRef>Task_pickup</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_delivered</bpmn:flowNodeRef></bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Khách đặt món"><bpmn:outgoing>Flow_start</bpmn:outgoing></bpmn:startEvent>
    <bpmn:task id="Task_total" name="Tính tổng tiền (món + ship + KM)"><bpmn:incoming>Flow_start</bpmn:incoming><bpmn:outgoing>Flow_totot</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="GW_online" name="Thanh toán online?"><bpmn:incoming>Flow_totot</bpmn:incoming><bpmn:outgoing>Flow_on_yes</bpmn:outgoing><bpmn:outgoing>Flow_on_no</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_pay" name="Gọi cổng thanh toán"><bpmn:incoming>Flow_on_yes</bpmn:incoming><bpmn:outgoing>Flow_topaid</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="GW_paid" name="Thu tiền thành công?"><bpmn:incoming>Flow_topaid</bpmn:incoming><bpmn:outgoing>Flow_paid_no</bpmn:outgoing><bpmn:outgoing>Flow_paid_yes</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_payfail" name="Thanh toán thất bại (dừng)"><bpmn:incoming>Flow_paid_no</bpmn:incoming></bpmn:endEvent>
    <bpmn:task id="Task_send" name="Gửi đơn tới nhà hàng"><bpmn:incoming>Flow_on_no</bpmn:incoming><bpmn:incoming>Flow_paid_yes</bpmn:incoming><bpmn:outgoing>Flow_toaccept</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="GW_accept" name="Nhà hàng nhận đơn trong 5 phút?"><bpmn:incoming>Flow_toaccept</bpmn:incoming><bpmn:outgoing>Flow_acc_no</bpmn:outgoing><bpmn:outgoing>Flow_acc_yes</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_refund" name="Hoàn tiền nếu đã thu online"><bpmn:incoming>Flow_acc_no</bpmn:incoming><bpmn:incoming>Flow_sh_no</bpmn:incoming><bpmn:outgoing>Flow_torefund</bpmn:outgoing></bpmn:task>
    <bpmn:endEvent id="End_cancel" name="Đơn bị hủy (dừng)"><bpmn:incoming>Flow_torefund</bpmn:incoming></bpmn:endEvent>
    <bpmn:task id="Task_prepare" name="Xác nhận &amp; chuẩn bị món"><bpmn:incoming>Flow_acc_yes</bpmn:incoming><bpmn:outgoing>Flow_toassign</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_assign" name="Tìm &amp; gán shipper gần nhất"><bpmn:incoming>Flow_toassign</bpmn:incoming><bpmn:outgoing>Flow_toship</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="GW_shipper" name="Có shipper nhận trong 15 phút?"><bpmn:incoming>Flow_toship</bpmn:incoming><bpmn:outgoing>Flow_sh_no</bpmn:outgoing><bpmn:outgoing>Flow_sh_yes</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_pickup" name="Lấy món &amp; giao tới khách"><bpmn:incoming>Flow_sh_yes</bpmn:incoming><bpmn:outgoing>Flow_todeliv</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="GW_delivered" name="Giao thành công?"><bpmn:incoming>Flow_todeliv</bpmn:incoming><bpmn:outgoing>Flow_dl_no</bpmn:outgoing><bpmn:outgoing>Flow_dl_yes</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_fail" name="Chuyển CSKH xử lý / hoàn tiền"><bpmn:incoming>Flow_dl_no</bpmn:incoming><bpmn:outgoing>Flow_tofail</bpmn:outgoing></bpmn:task>
    <bpmn:endEvent id="End_failed" name="Giao thất bại (dừng)"><bpmn:incoming>Flow_tofail</bpmn:incoming></bpmn:endEvent>
    <bpmn:task id="Task_receive" name="Khách nhận món"><bpmn:incoming>Flow_dl_yes</bpmn:incoming><bpmn:outgoing>Flow_todone</bpmn:outgoing></bpmn:task>
    <bpmn:endEvent id="End_done" name="Hoàn tất đơn"><bpmn:incoming>Flow_todone</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start" name="" sourceRef="Start_1" targetRef="Task_total"/>
    <bpmn:sequenceFlow id="Flow_totot" name="" sourceRef="Task_total" targetRef="GW_online"/>
    <bpmn:sequenceFlow id="Flow_on_yes" name="Có" sourceRef="GW_online" targetRef="Task_pay"/>
    <bpmn:sequenceFlow id="Flow_on_no" name="COD" sourceRef="GW_online" targetRef="Task_send"/>
    <bpmn:sequenceFlow id="Flow_topaid" name="" sourceRef="Task_pay" targetRef="GW_paid"/>
    <bpmn:sequenceFlow id="Flow_paid_no" name="Không" sourceRef="GW_paid" targetRef="End_payfail"/>
    <bpmn:sequenceFlow id="Flow_paid_yes" name="Có" sourceRef="GW_paid" targetRef="Task_send"/>
    <bpmn:sequenceFlow id="Flow_toaccept" name="" sourceRef="Task_send" targetRef="GW_accept"/>
    <bpmn:sequenceFlow id="Flow_acc_no" name="Không / từ chối" sourceRef="GW_accept" targetRef="Task_refund"/>
    <bpmn:sequenceFlow id="Flow_torefund" name="" sourceRef="Task_refund" targetRef="End_cancel"/>
    <bpmn:sequenceFlow id="Flow_acc_yes" name="Có" sourceRef="GW_accept" targetRef="Task_prepare"/>
    <bpmn:sequenceFlow id="Flow_toassign" name="" sourceRef="Task_prepare" targetRef="Task_assign"/>
    <bpmn:sequenceFlow id="Flow_toship" name="" sourceRef="Task_assign" targetRef="GW_shipper"/>
    <bpmn:sequenceFlow id="Flow_sh_no" name="Không (15p)" sourceRef="GW_shipper" targetRef="Task_refund"/>
    <bpmn:sequenceFlow id="Flow_sh_yes" name="Có" sourceRef="GW_shipper" targetRef="Task_pickup"/>
    <bpmn:sequenceFlow id="Flow_todeliv" name="" sourceRef="Task_pickup" targetRef="GW_delivered"/>
    <bpmn:sequenceFlow id="Flow_dl_no" name="Không" sourceRef="GW_delivered" targetRef="Task_fail"/>
    <bpmn:sequenceFlow id="Flow_tofail" name="" sourceRef="Task_fail" targetRef="End_failed"/>
    <bpmn:sequenceFlow id="Flow_dl_yes" name="Có" sourceRef="GW_delivered" targetRef="Task_receive"/>
    <bpmn:sequenceFlow id="Flow_todone" name="" sourceRef="Task_receive" targetRef="End_done"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape bpmnElement="Participant_1" isHorizontal="false"><dc:Bounds x="0" y="0" width="1190" height="1760"/></bpmndi:BPMNShape>
