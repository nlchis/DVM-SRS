// Schema spaced-repetition — mẫu chuẩn (đã validate qua: dbml2sql example-dbdiagram.dbml --postgres)
// Nguồn: srs/spaced-repetition-erd.md (chuyển 1-1, nâng type gọn → kiểu DB thật)

Table learners {
  id uuid [pk]
  email varchar [unique, not null, note: 'địa chỉ liên hệ']
  display_name varchar [note: 'tên hiển thị']
  created_at timestamp [default: `now()`]
}

Table decks {
  id uuid [pk]
  learner_id uuid [ref: > learners.id, note: 'bộ thẻ của học viên nào']
  name varchar [not null, note: 'tên bộ thẻ']
  description text [note: 'mô tả ngắn, có thể rỗng']
  created_at timestamp [default: `now()`]
}

Table cards {
  id uuid [pk]
  deck_id uuid [ref: > decks.id, note: 'thuộc bộ thẻ nào']
  front varchar [not null, note: 'mặt trước — từ vựng']
  back text [not null, note: 'mặt sau — nghĩa / ví dụ']
  next_review_at timestamp [note: 'thời điểm ôn kế tiếp']
  interval_days int [default: 1, note: 'khoảng cách ngày tới lần ôn sau']
  ease decimal [default: 2.5, note: 'độ dễ hiện tại của thẻ (SM-2)']
  streak int [default: 0, note: 'số lần ôn liên tiếp đúng']

  Indexes {
    (deck_id, next_review_at) [name: 'idx_card_due']
  }
}

Enum card_recall {
  forgot [note: 'quên']
  fuzzy [note: 'mơ hồ']
  remembered [note: 'nhớ']
  mastered [note: 'thuộc lòng']
}

Table review_logs {
  id uuid [pk]
  card_id uuid [ref: > cards.id, note: 'ôn cho thẻ nào']
  learner_id uuid [ref: > learners.id, note: 'ai ôn']
  reviewed_at timestamp [not null, note: 'thời điểm ôn']
  recall card_recall [not null, note: 'mức nhớ được lần này']
  next_interval_days int [note: 'khoảng cách kế tiếp tính sau lần ôn này']

  Indexes {
    (learner_id, reviewed_at) [name: 'idx_review_learner_time']
  }
}
